# ============================================================
# Symbiont Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is never committed to version control.
# ============================================================

# --- Required: Apex Controller ---

# Local IP or hostname of the Neptune Apex controller (no trailing slash)
SYMBIONT_APEX_URL=http://192.168.1.100

# Apex login username (same as Apex Fusion login)
SYMBIONT_APEX_USER=admin

# Apex login password
SYMBIONT_APEX_PASS=

# --- Database Paths ---

# DuckDB file for time-series data (probe readings, outlet states, power events)
# Written only by the poller; read-only for the API server.
SYMBIONT_DB_PATH=telemetry.db

# SQLite file for application state (tokens, alerts, event log, config)
# Written only by the API server; never touched by the poller.
SYMBIONT_SQLITE_PATH=app.db

# --- Poller ---

# How often to poll the Apex controller (Go duration string: 10s, 30s, 1m, etc.)
SYMBIONT_POLL_INTERVAL=10s

# --- API Server ---

# Port the HTTP API server listens on
SYMBIONT_API_PORT=8420

# Bearer token for API authentication.
# Generated automatically on first run and printed to stdout once.
# Set here if running the CLI or MCP server against this API.
SYMBIONT_TOKEN=

# --- Logging ---

# Log level: debug, info, warn, error
SYMBIONT_LOG_LEVEL=info

# --- Retention ---

# How many days of data to keep in DuckDB (cleanup runs weekly)
SYMBIONT_RETENTION_DAYS=365

# --- Notifications (optional) ---

# ntfy.sh topic URL for alert notifications (leave blank to disable)
SYMBIONT_NTFY_URL=

# --- Backup (optional) ---

# Directory where nightly backups are written (defaults to ./backups)
SYMBIONT_BACKUP_DIR=./backups
